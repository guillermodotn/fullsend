#!/bin/bash

# lint-scaffold-workflows - Run actionlint on scaffold workflow templates
#
# The pre-commit actionlint hook only checks .github/workflows/ in the repo
# root. Scaffold templates under internal/scaffold/fullsend-repo/ are skipped,
# so syntax errors (like empty secrets sections) slip through to enrolled repos.
#
# This script copies scaffold workflows and templates into a temporary
# .github/workflows/ directory, substitutes __ORG__ placeholders, and runs
# actionlint on the result.

set -euo pipefail

SCAFFOLD_DIR="internal/scaffold/fullsend-repo"
WORKFLOW_DIR="${SCAFFOLD_DIR}/.github/workflows"
TEMPLATE_DIR="${SCAFFOLD_DIR}/templates"

ACTIONLINT="actionlint"
if ! command -v actionlint &>/dev/null; then
  if command -v go &>/dev/null; then
    ACTIONLINT="go run github.com/rhysd/actionlint/cmd/actionlint@latest"
  else
    echo "ERROR: actionlint not found and go not available. Run 'make bootstrap' to install it." >&2
    exit 1
  fi
fi

tmpdir=$(mktemp -d)
trap 'rm -rf "${tmpdir}"' EXIT

mkdir -p "${tmpdir}/.github/workflows"
git -C "${tmpdir}" init -q

# Copy real workflow files
if [[ -d "${WORKFLOW_DIR}" ]]; then
  for f in "${WORKFLOW_DIR}"/*.yml "${WORKFLOW_DIR}"/*.yaml; do
    [[ -e "${f}" ]] || continue
    cp "${f}" "${tmpdir}/.github/workflows/"
  done
fi

# Copy templates with placeholder substitution
if [[ -d "${TEMPLATE_DIR}" ]]; then
  for f in "${TEMPLATE_DIR}"/*.yml "${TEMPLATE_DIR}"/*.yaml; do
    [[ -e "${f}" ]] || continue
    sed 's/__ORG__/placeholder-org/g' "${f}" > "${tmpdir}/.github/workflows/$(basename "${f}")"
  done
fi

# Check we found something to lint
found=0
for f in "${tmpdir}"/.github/workflows/*.yml "${tmpdir}"/.github/workflows/*.yaml; do
  [[ -e "${f}" ]] && found=1 && break
done
if [[ "${found}" -eq 0 ]]; then
  echo "No scaffold workflow files found to lint"
  exit 0
fi

# Run actionlint from the temp dir so it sees .github/workflows/
#
# Ignore patterns (keep in sync with .pre-commit-config.yaml where applicable):
#   - "queue" concurrency key: GitHub merge queue extension, not yet in actionlint schema
#   - workflow_repository: newer job context property, not yet in actionlint type defs
#   - shellcheck SC2016: info-level "expressions don't expand in single quotes" — intentional
output=$(cd "${tmpdir}" && $ACTIONLINT \
  -ignore 'unexpected key "queue" for "concurrency"' \
  -ignore 'property "workflow_repository" is not defined' \
  -ignore 'SC2016' \
  2>&1) || {
  # Rewrite paths back to real source paths for readable output.
  # actionlint prints relative paths (we cd into tmpdir), so match
  # against .github/workflows/ without the tmpdir prefix.
  echo "${output}" \
    | sed "s|\.github/workflows/\(dispatch\.yml\)|${WORKFLOW_DIR}/\1|g" \
    | sed "s|\.github/workflows/\(reusable-[^ ]*\)|${WORKFLOW_DIR}/\1|g" \
    | sed "s|\.github/workflows/|${TEMPLATE_DIR}/|g" \
    >&2
  exit 1
}

echo "OK: Scaffold workflow templates pass actionlint"
